 .env.example - Copy file ini menjadi .env dan isi dengan credentials kamu

# ========== GOOGLE CLOUD & SHEETS ==========
GOOGLE_SHEETS_API_KEY=path/to/service_account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ========== TIDB DATABASE ==========
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_username_here
TIDB_PASSWORD=your_tidb_password_here
TIDB_DATABASE=RAG

# ========== OPENAI API ==========
OPENAI_API_KEY=sk-proj-your_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ========== TELEGRAM BOT ==========
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ========== LOGGING & DEBUG ==========
LOG_LEVEL=INFO
DEBUG_MODE=False

# ========== SCHEDULER (untuk auto-update) ==========
SCHEDULER_ENABLED=True
SCHEDULER_HOUR=10
SCHEDULER_MINUTE=0
SCHEDULER_DAY_OF_WEEK=0-4  # Weekday only (0=Monday, 4=Friday)

# ========== NOTES ==========
# 1. Copy file ini: cp .env.example .env
# 2. Edit .env dengan credentials kamu
# 3. .env akan di-load otomatis di code via python-dotenv
# 4. Untuk credentials:
#    - GOOGLE_SHEETS_API_KEY: path ke service account JSON (download dari Google Cloud)
#    - GOOGLE_SPREADSHEET_ID: buka spreadsheet, copy ID dari URL
#    - TIDB credentials: dari TiDB Cloud dashboard
#    - OPENAI_API_KEY: dari platform.openai.com
#    - TELEGRAM_BOT_TOKEN: dari BotFather di Telegram
